{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-drift.sh",
            "timeout": 15,
            "statusMessage": "Checking drift (docs · branch · PRs · types)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-docs-guard.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
